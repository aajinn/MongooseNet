<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>MongooseNet</id>
    <version>1.0.0</version>
    <authors>Ajin Varghese Chandy</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/aajinn/MongooseNet</projectUrl>
    <description>A lightweight Mongoose-inspired ODM for MongoDB in .NET. Provides a generic repository, fluent LINQ queries, pre-save hooks, automatic timestamp management, and one-line DI registration.</description>
    <copyright>Copyright © 2026 Ajin Varghese Chandy</copyright>
    <tags>mongodb odm repository mongoose dotnet nosql database</tags>
    <repository type="git" url="https://github.com/aajinn/MongooseNet" />
    <dependencies>
